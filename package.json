{
  "name": "jolt-ts",
  "version": "0.1.0",
  "description": "TypeScript-first ergonomic wrapper for Jolt Physics WASM",
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./native/jolt/dist/*": "./native/jolt/dist/*"
  },
  "files": [
    "dist",
    "src",
    "docs/api-directions.md",
    "native/jolt/dist",
    "native/jolt/LICENSE",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:native": "sh native/jolt/build.sh && node scripts/patch-bundler-compat.mjs",
    "check": "tsc -p tsconfig.json --noEmit",
    "check:native": "node scripts/check-native-artifacts.mjs",
    "prepack": "pnpm run build && pnpm run patch:native && pnpm run check:native",
    "test": "vitest run",
    "patch:native": "node scripts/patch-bundler-compat.mjs",
    "docs:dev": "pnpm run build && pnpm --filter jolt-ts-docs dev",
    "docs:build": "pnpm run build && pnpm --filter jolt-ts-docs build",
    "docs:preview": "pnpm --filter jolt-ts-docs preview"
  },
  "keywords": [
    "jolt",
    "jolt-physics",
    "physics",
    "physics-engine",
    "game-physics",
    "wasm",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/snackdotgame/jolt-ts.git"
  },
  "bugs": {
    "url": "https://github.com/snackdotgame/jolt-ts/issues"
  },
  "homepage": "https://github.com/snackdotgame/jolt-ts#readme",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0",
    "webidl-dts-gen": "^1.11.0"
  }
}
